{
  "name": "pi-workbench",
  "version": "0.11.1",
  "private": true,
  "description": "A polished terminal workbench, theme, and extension suite for Pi.",
  "type": "module",
  "homepage": "https://github.com/amAbdoMo/Pi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amAbdoMo/Pi.git"
  },
  "bugs": {
    "url": "https://github.com/amAbdoMo/Pi/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-theme",
    "terminal-ui",
    "coding-agent",
    "mcp",
    "rtl",
    "subagents"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "themes": [
      "./themes"
    ]
  },
  "scripts": {
    "capture": "node scripts/capture-config.mjs",
    "test": "node scripts/validate.mjs && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "arabic-reshaper": "1.1.0",
    "bidi-js": "1.0.3",
    "jsonc-parser": "3.3.1"
  }
}
